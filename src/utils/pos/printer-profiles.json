{
  "ascii": {
    "description": "ASCII-only. NFD-normalizes and strips all combining marks and non-ASCII characters. Safe for any ESC/POS printer regardless of firmware.",
    "encoding": "ascii"
  },
  "utf8": {
    "description": "UTF-8 pass-through. Only strips raw ESC/POS control bytes (0x00-0x08, 0x0B, 0x0C, 0x0E-0x1F, 0x7F). Requires printer firmware with Unicode/UTF-8 support.",
    "encoding": "utf-8"
  },
