MEDUSA_ADMIN_EMAIL=admin@example.com
MEDUSA_ADMIN_PASSWORD=your_admin_password
STORE_CORS=http://localhost:1420
ADMIN_CORS=http://localhost:1420
AUTH_CORS=http://localhost:1420
JWT_SECRET=your-jwt-secret
COOKIE_SECRET=your-cookie-secret
