{
  "name": "medusa-pos",
  "version": "0.0.14",
  "private": false,
  "author": "Nari Solutions",
  "license": "Apache-2.0",
  "homepage": "https://pos.nari.ge",
  "repository": {
    "type": "git",
    "url": "https://github.com/narisolutions/medusa-pos.git"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:staging": "vite --mode staging",
    "dev:production": "vite --mode production",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build",
    "build:staging": "tsc && vite build --mode staging",
    "build:production": "tsc && vite build --mode production",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev -- --features devtools",
    "tauri:build": "tauri build",
    "tauri:build:debug": "RUST_LOG=debug tauri build --debug",
    "android:build:apk": "tauri android build --apk",
    "android:build:apk:debug": "tauri android build --apk -d",
    "android:build:apk:split": "tauri android build --apk --split-per-abi",
    "android:build:apk:arm64": "tauri android build --apk --target aarch64",
    "test:env:up": "docker compose -f integration-tests/docker-compose.yml --env-file integration-tests/.env up --build -d",
    "test:env:down": "docker compose -f integration-tests/docker-compose.yml down",
    "test:env:reset": "docker compose -f integration-tests/docker-compose.yml down -v",
    "test:env:logs": "docker compose -f integration-tests/docker-compose.yml logs -f medusa"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@medusajs/js-sdk": "^2.15.3",
    "@medusajs/types": "^2.15.3",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@shadcn/ui": "^0.0.4",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-table": "^8.21.3",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "i18next": "^26.2.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.75.0",
    "react-i18next": "^17.0.7",
    "react-router-dom": "^7.15.1",
    "sidebar": "^1.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.1",
    "@types/react-day-picker": "^5.3.0",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.3",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.10"
  }
}
