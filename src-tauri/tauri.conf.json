{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Medusa POS",
  "version": "../package.json",
  "identifier": "ge.nari.medusa-pos",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist",
    "removeUnusedCommands": false
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Medusa POS",
        "width": 1920,
        "height": 1080,
        "fullscreen": true,
        "visible": true,
        "backgroundColor": "#09090b",
        "additionalBrowserArgs": "--disable-features=VizDisplayCompositor"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPLOCALDATA/**"]
      }
    },
    "withGlobalTauri": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/narisolutions/medusa-pos/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQzMUNERjIyQjM3OUMyOTkKUldTWndubXpJdDhjMC9nTkMwbGJ4cHZNNXR2S05qcnBpd1liaytjSEVkUGVZV09Zek0zWnVGSUgK"
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Nari Solutions",
    "copyright": "Copyright 2026 Nari Solutions",
    "createUpdaterArtifacts": true,
    "targets": ["appimage", "dmg", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
