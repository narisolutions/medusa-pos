{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "medusa-pos",
  "version": "../package.json",
  "identifier": "io.medusa.pos",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "title": "Medusa POS",
        "width": 1920,
        "height": 1080,
        "additionalBrowserArgs": "--disable-features=VizDisplayCompositor"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPLOCALDATA/**"]
      }
    },
    "withGlobalTauri": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/narisolutions/medusa-pos/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJERDhBRUM1N0Y4NzkyOUIKUldTYmtvZC94YTdZdldyeG5uaWlOUDF1MHN3eXRNZ2xhVFNqREh5MjFzL2FEY2pGdndsRmtEa0IK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["appimage", "dmg", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
